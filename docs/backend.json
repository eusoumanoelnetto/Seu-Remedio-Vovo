
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Armazena informações de perfil dos usuários do app Seu Remédio Vovó.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único do perfil do usuário."
        },
        "email": {
          "type": "string",
          "description": "E-mail do usuário.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "Nome de exibição do usuário."
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL da imagem de perfil.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Data de criação.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Data da última atualização.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "displayName",
        "createdAt"
      ]
    },
    "MedicineScan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MedicineScan",
      "type": "object",
      "description": "Registra cada instância em que um usuário utiliza o app para escanear um remédio ou receita.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único da leitura."
        },
        "userId": {
          "type": "string",
          "description": "Referência ao usuário que realizou a leitura."
        },
        "scannedImageUrl": {
          "type": "string",
          "description": "URL da imagem capturada.",
          "format": "uri"
        },
        "medicineName": {
          "type": "string",
          "description": "Nome identificado do remédio."
        },
        "simplifiedExplanation": {
          "type": "string",
          "description": "Explicação simplificada gerada pela IA."
        },
        "scanDateTime": {
          "type": "string",
          "description": "Data e hora da leitura.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "scannedImageUrl",
        "simplifiedExplanation",
        "scanDateTime"
      ]
    },
    "ActiveMedicine": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActiveMedicine",
      "type": "object",
      "description": "Remédios que a vovó está tomando atualmente com seus respectivos horários.",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID único do remédio na lista ativa."
        },
        "name": {
          "type": "string",
          "description": "Nome do remédio."
        },
        "schedule": {
          "type": "string",
          "description": "Horário ou intervalo (ex: de 8 em 8 horas)."
        },
        "purpose": {
          "type": "string",
          "description": "Finalidade curta do remédio."
        },
        "addedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "schedule"]
    }
  },
  "auth": {
    "providers": [
      "google",
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Perfis de usuários individuais."
        }
      },
      {
        "path": "/users/{userId}/medicine_scans/{scanId}",
        "definition": {
          "entityName": "MedicineScan",
          "schema": {
            "$ref": "#/backend/entities/MedicineScan"
          },
          "description": "Histórico de leituras de medicamentos e receitas."
        }
      },
      {
        "path": "/users/{userId}/active_medicines/{medId}",
        "definition": {
          "entityName": "ActiveMedicine",
          "schema": {
            "$ref": "#/backend/entities/ActiveMedicine"
          },
          "description": "Lista de remédios que a vovó toma no dia a dia."
        }
      }
    ]
  }
}

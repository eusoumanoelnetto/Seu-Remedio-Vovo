
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Armazena informações de perfil dos usuários do app Seu Remédio Vovó, permitindo gerenciar leituras de medicamentos e receitas.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único do perfil do usuário."
        },
        "email": {
          "type": "string",
          "description": "E-mail do usuário.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "Nome de exibição do usuário."
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL da imagem de perfil.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Data de criação.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Data da última atualização.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "displayName",
        "createdAt"
      ]
    },
    "MedicineScan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MedicineScan",
      "type": "object",
      "description": "Registra cada instância em que um usuário utiliza o app para escanear um remédio ou receita.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único da leitura."
        },
        "userId": {
          "type": "string",
          "description": "Referência ao usuário que realizou a leitura."
        },
        "scannedImageUrl": {
          "type": "string",
          "description": "URL da imagem capturada.",
          "format": "uri"
        },
        "medicineName": {
          "type": "string",
          "description": "Nome identificado do remédio."
        },
        "simplifiedExplanation": {
          "type": "string",
          "description": "Explicação simplificada gerada pela IA."
        },
        "rawAiResponse": {
          "type": "string",
          "description": "Resposta bruta da IA (opcional)."
        },
        "scanDateTime": {
          "type": "string",
          "description": "Data e hora da leitura.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "scannedImageUrl",
        "simplifiedExplanation",
        "scanDateTime"
      ]
    }
  },
  "auth": {
    "providers": [
      "google",
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Perfis de usuários individuais.",
          "params": [
            {
              "name": "userId",
              "description": "O UID do usuário."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/medicine_scans/{scanId}",
        "definition": {
          "entityName": "MedicineScan",
          "schema": {
            "$ref": "#/backend/entities/MedicineScan"
          },
          "description": "Histórico de leituras de medicamentos e receitas do usuário.",
          "params": [
            {
              "name": "userId",
              "description": "UID do dono do histórico."
            },
            {
              "name": "scanId",
              "description": "ID único da leitura."
            }
          ]
        }
      }
    ],
    "reasoning": "Estrutura centrada no usuário para garantir privacidade e facilidade de acesso ao histórico pessoal."
  }
}

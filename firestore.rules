rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SEU REMÉDIO VOVÓ - CONFIGURAÇÃO DE SEGURANÇA
     *
     * Filosofia Central:
     * Este conjunto de regras impõe um modelo estrito de propriedade do usuário.
     * O aplicativo é projetado para ser privado, onde os usuários só podem acessar os dados que criaram.
     */

    // --- Funções Auxiliares ---

    /** @description Verifica se a requisição é feita por um usuário autenticado. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Verifica se o UID do usuário autenticado corresponde ao userId fornecido. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combina a verificação de propriedade com a verificação de que o documento já existe. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Regras de Coleção ---

    /**
     * @description Regras para o perfil do usuário e suas subcoleções.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Histórico de leituras de medicamentos e receitas.
       */
      match /medicine_scans/{scanId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Lista de remédios ativos que a vovó está tomando.
       */
      match /active_medicines/{medId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

  }
}